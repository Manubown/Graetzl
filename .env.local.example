# Copy this file to `.env.local` and fill in the values from your
# Supabase project (Project Settings → API).
#
# All public variables are prefixed NEXT_PUBLIC_ so they're available
# in the browser. Server-only secrets (e.g. SUPABASE_SERVICE_ROLE_KEY)
# must NOT use the NEXT_PUBLIC_ prefix.

NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Used only on the server (admin tooling, Week 3+).
# SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
