{
  "name": "graetzl",
  "version": "0.1.0",
  "private": true,
  "description": "Grätzl — the anti-TripAdvisor, a non-commercial locally-curated city map.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
