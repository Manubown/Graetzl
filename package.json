    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lighthouse": "^13.3.0",
    "supabase": "^2.98.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
